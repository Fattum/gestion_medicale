<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.gestion_medicale.controllers.RendezVousController"
      spacing="16" styleClass="view-container">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="📅 Gestion des Rendez-vous" styleClass="view-title"/>

    <SplitPane dividerPositions="0.55" VBox.vgrow="ALWAYS">

        <!-- TABLE -->
        <VBox spacing="8">
            <TableView fx:id="tableRdv" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                    <TableColumn fx:id="colHeure" text="Heure" prefWidth="80"/>
                    <TableColumn fx:id="colPatient" text="Patient" prefWidth="150"/>
                    <TableColumn fx:id="colMedecin" text="Médecin" prefWidth="150"/>
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="100"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
        </VBox>

        <!-- FORM -->
        <ScrollPane fitToWidth="true">
            <VBox spacing="10" styleClass="form-panel">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <Label text="Nouveau Rendez-vous" styleClass="form-section-title"/>

                <Label text="Patient *" styleClass="form-label"/>
                <ComboBox fx:id="cmbPatient" promptText="Sélectionner le patient"
                          maxWidth="Infinity" styleClass="form-field"/>

                <Label text="Médecin *" styleClass="form-label"/>
                <ComboBox fx:id="cmbMedecin" promptText="Sélectionner le médecin"
                          maxWidth="Infinity" styleClass="form-field"/>

                <Label text="Disponibilité (optionnel)" styleClass="form-label"/>
                <ComboBox fx:id="cmbDisponibilite" promptText="Choisir une disponibilité"
                          maxWidth="Infinity" styleClass="form-field"/>

                <Label text="Date *" styleClass="form-label"/>
                <DatePicker fx:id="dpDate" maxWidth="Infinity" styleClass="form-field"/>

                <Label text="Heure * (HH:MM)" styleClass="form-label"/>
                <TextField fx:id="txtHeure" promptText="ex: 10:30" styleClass="form-field"/>

                <Label text="Statut" styleClass="form-label"/>
                <ComboBox fx:id="cmbStatut" promptText="Statut"
                          maxWidth="Infinity" styleClass="form-field"/>

                <Label fx:id="lblMessage" text="" wrapText="true"/>

                <Button text="✚ Ajouter RDV" onAction="#handleAjouter"
                        styleClass="btn-primary" maxWidth="Infinity"/>
                <Button text="✎ Modifier Statut" onAction="#handleModifierStatut"
                        styleClass="btn-secondary" maxWidth="Infinity"/>
                <Button text="✕ Supprimer" onAction="#handleSupprimer"
                        styleClass="btn-danger" maxWidth="Infinity"/>
                <Button text="↺ Effacer" onAction="#handleEffacer"
                        styleClass="btn-outline" maxWidth="Infinity"/>
            </VBox>
        </ScrollPane>
    </SplitPane>
</VBox>