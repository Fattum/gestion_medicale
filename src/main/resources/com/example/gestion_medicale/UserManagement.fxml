<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.controlsfx.control.CheckComboBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.gestion_medicale.controllers.UserController"
      spacing="16" styleClass="view-container">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="👥 Gestion des Utilisateurs" styleClass="view-title"/>

    <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">

        <!-- TABLE -->
        <VBox spacing="8">
            <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="200"/>
                    <TableColumn fx:id="colRole" text="Rôle" prefWidth="120"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
        </VBox>

        <!-- FORM -->
        <VBox spacing="12" styleClass="form-panel">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <Label text="Informations Utilisateur" styleClass="form-section-title"/>

            <Label text="Nom *" styleClass="form-label"/>
            <TextField fx:id="txtNom" promptText="Nom d'utilisateur" styleClass="form-field"/>

            <Label text="Mot de passe *" styleClass="form-label"/>
            <PasswordField fx:id="txtMotDePasse" promptText="Mot de passe" styleClass="form-field"/>

            <Label text="Rôle *" styleClass="form-label"/>
            <ComboBox fx:id="cmbRole" promptText="Sélectionner le rôle" maxWidth="Infinity" styleClass="form-field"/>

            <VBox fx:id="boxPatientLink" spacing="6">
                <Label text="Patient à lier *" styleClass="form-label"/>
                <ComboBox fx:id="cmbPatientLink" promptText="Sélectionner le patient"
                          maxWidth="Infinity" styleClass="form-field"/>
            </VBox>

            <VBox fx:id="boxSecretaireDoctors" spacing="6">
                <Label text="Médecins liés (sélection multiple) *" styleClass="form-label"/>
                <CheckComboBox fx:id="cmbDoctorsLink" maxWidth="Infinity"/>
            </VBox>

            <VBox fx:id="boxDoctorInfo" spacing="6">
                <Label text="Médecin" styleClass="form-label"/>
                <ComboBox fx:id="cmbMedecinLink" promptText="Sélectionner le médecin"
                          maxWidth="Infinity" styleClass="form-field"/>
                <Label text="Ce compte sera lié au médecin sélectionné (pas de création d’un nouveau médecin ici)."
                       wrapText="true" styleClass="info-label"/>
            </VBox>

            <Label fx:id="lblMessage" text="" wrapText="true"/>

            <HBox spacing="8">
                <Button text="✚ Ajouter" onAction="#handleAjouter" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="✎ Modifier" onAction="#handleModifier" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
            <HBox spacing="8">
                <Button text="✕ Supprimer" onAction="#handleSupprimer" styleClass="btn-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="↺ Effacer" onAction="#handleEffacer" styleClass="btn-outline" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </VBox>
    </SplitPane>
</VBox>