<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.gestion_medicale.controllers.PatientController"
      spacing="16" styleClass="view-container">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="🧑 Gestion des Patients" styleClass="view-title"/>

    <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">

        <!-- TABLE -->
        <VBox spacing="8">
            <TableView fx:id="tablePatients" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="180"/>
                    <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="130"/>
                    <TableColumn fx:id="colAdresse" text="Adresse" prefWidth="200"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
        </VBox>

        <!-- FORM -->
        <VBox spacing="12" styleClass="form-panel">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <Label text="Informations Patient" styleClass="form-section-title"/>

            <Label text="Nom complet *" styleClass="form-label"/>
            <TextField fx:id="txtNom" promptText="Nom du patient" styleClass="form-field"/>

            <Label text="Téléphone" styleClass="form-label"/>
            <TextField fx:id="txtTelephone" promptText="Numéro de téléphone" styleClass="form-field"/>

            <Label text="Adresse" styleClass="form-label"/>
            <TextArea fx:id="txtAdresse" promptText="Adresse complète"
                      prefRowCount="3" styleClass="form-field" wrapText="true"/>

            <Label text="ℹ Un dossier médical sera créé automatiquement."
                   styleClass="info-label" wrapText="true"/>

            <Label fx:id="lblMessage" text="" wrapText="true"/>

            <HBox spacing="8">
                <Button text="✚ Ajouter" onAction="#handleAjouter" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="✎ Modifier" onAction="#handleModifier" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
            <HBox spacing="8">
                <Button text="✕ Supprimer" onAction="#handleSupprimer" styleClass="btn-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="↺ Effacer" onAction="#handleEffacer" styleClass="btn-outline" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </VBox>
    </SplitPane>
</VBox>