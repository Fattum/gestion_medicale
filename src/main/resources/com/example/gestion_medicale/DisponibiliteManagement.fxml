<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.gestion_medicale.controllers.DisponibiliteController"
      spacing="16" styleClass="view-container">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="🗓 Gestion des Disponibilités" styleClass="view-title"/>

    <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">

        <!-- TABLE -->
        <VBox spacing="8">
            <TableView fx:id="tableDispos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="120"/>
                    <TableColumn fx:id="colDebut" text="Heure Début" prefWidth="110"/>
                    <TableColumn fx:id="colFin" text="Heure Fin" prefWidth="110"/>
                    <TableColumn fx:id="colMedecin" text="Médecin" prefWidth="150"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
        </VBox>

        <!-- FORM -->
        <VBox spacing="12" styleClass="form-panel">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <Label text="Nouvelle Disponibilité" styleClass="form-section-title"/>

            <Label text="Date *" styleClass="form-label"/>
            <DatePicker fx:id="dpDate" promptText="Sélectionner la date"
                        maxWidth="Infinity" styleClass="form-field"/>

            <Label text="Heure de début * (HH:MM)" styleClass="form-label"/>
            <TextField fx:id="txtHeureDebut" promptText="ex: 09:00" styleClass="form-field"/>

            <Label text="Heure de fin * (HH:MM)" styleClass="form-label"/>
            <TextField fx:id="txtHeureFin" promptText="ex: 17:00" styleClass="form-field"/>

            <Label fx:id="lblMessage" text="" wrapText="true"/>

            <HBox spacing="8">
                <Button text="✚ Ajouter" onAction="#handleAjouter" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="✎ Modifier" onAction="#handleModifier" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
            <HBox spacing="8">
                <Button text="✕ Supprimer" onAction="#handleSupprimer" styleClass="btn-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="↺ Effacer" onAction="#handleEffacer" styleClass="btn-outline" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </VBox>
    </SplitPane>
</VBox>