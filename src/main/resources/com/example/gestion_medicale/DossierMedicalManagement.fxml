<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.gestion_medicale.controllers.DossierMedicalController"
      spacing="16" styleClass="view-container">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="📋 Dossiers Médicaux" styleClass="view-title"/>

    <SplitPane dividerPositions="0.4" VBox.vgrow="ALWAYS">

        <!-- TABLE -->
        <VBox spacing="8">
            <TableView fx:id="tableDossiers" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colPatient" text="Patient" prefWidth="200"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
        </VBox>

        <!-- FORM -->
        <VBox spacing="12" styleClass="form-panel">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <Label text="Contenu du Dossier Médical" styleClass="form-section-title"/>

            <Label text="Historique médical" styleClass="form-label"/>
            <TextArea fx:id="txtHistorique" promptText="Historique des maladies, traitements..."
                      prefRowCount="4" styleClass="form-field" wrapText="true"
                      VBox.vgrow="ALWAYS"/>

            <Label text="Allergies" styleClass="form-label"/>
            <TextArea fx:id="txtAllergies" promptText="Médicaments, aliments allergènes..."
                      prefRowCount="3" styleClass="form-field" wrapText="true"/>

            <Label text="Observations" styleClass="form-label"/>
            <TextArea fx:id="txtObservations" promptText="Observations médicales récentes..."
                      prefRowCount="4" styleClass="form-field" wrapText="true"
                      VBox.vgrow="ALWAYS"/>

            <Label fx:id="lblMessage" text="" wrapText="true"/>

            <HBox spacing="8">
                <Button text="💾 Enregistrer" onAction="#handleModifier"
                        styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="↺ Effacer" onAction="#handleEffacer"
                        styleClass="btn-outline" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </VBox>
    </SplitPane>
</VBox>