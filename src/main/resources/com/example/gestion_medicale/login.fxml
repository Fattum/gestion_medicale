<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.gestion_medicale.controllers.LoginController"
      alignment="CENTER" spacing="20"
      styleClass="login-container">

    <padding><Insets top="40" right="50" bottom="40" left="50"/></padding>

    <Label text="🏥 Gestion Médicale" styleClass="login-title"/>

    <VBox spacing="12" maxWidth="300">
        <Label text="Nom d'utilisateur" styleClass="form-label"/>
        <TextField fx:id="txtNom" promptText="Entrez votre nom" styleClass="form-field"/>

        <Label text="Mot de passe" styleClass="form-label"/>
        <PasswordField fx:id="txtMotDePasse" promptText="Entrez votre mot de passe" styleClass="form-field"/>

        <Label fx:id="lblErreur" text="" styleClass="error-label" wrapText="true"/>

        <Button text="Se connecter" onAction="#handleLogin"
                styleClass="btn-primary" maxWidth="Infinity"/>
    </VBox>
</VBox>